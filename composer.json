{
    "name": "markup-carve/carve-php-media-embed",
    "description": "Opt-in Carve extension that embeds audio/video from 30+ providers via dereuromark/media-embed.",
    "type": "library",
    "license": "MIT",
    "keywords": ["carve", "markup", "media", "embed", "iframe", "video", "audio", "youtube"],
    "authors": [
        {
            "name": "Mark Scherer",
            "homepage": "https://www.dereuromark.de"
        }
    ],
    "support": {
        "issues": "https://github.com/markup-carve/carve-php-media-embed/issues",
        "source": "https://github.com/markup-carve/carve-php-media-embed"
    },
    "require": {
        "php": ">=8.2",
        "markup-carve/carve-php": "^0.1.1",
        "dereuromark/media-embed": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5 || ^12.0 || ^13.0",
        "phpstan/phpstan": "^2.0",
        "squizlabs/php_codesniffer": "^4.0",
        "php-collective/code-sniffer": "^0.6",
        "dealerdirect/phpcodesniffer-composer-installer": "*"
    },
    "autoload": {
        "psr-4": {
            "MarkupCarve\\MediaEmbed\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MarkupCarve\\MediaEmbed\\Test\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse",
        "cs-check": "phpcs",
        "cs-fix": "phpcbf"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "extra": {
        "branch-alias": {
            "dev-master": "1.0.x-dev"
        }
    }
}
